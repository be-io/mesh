# syntax=docker/dockerfile:1.3

FROM 10.12.0.78:5000/cosmos/ci:latest AS ci


FROM golang:1.19.4-alpine

RUN sed -i 's/dl-cdn.alpinelinux.org/mirrors.aliyun.com/g' /etc/apk/repositories
RUN set -eux; arch="$(apk --print-arch)"; \
    case "$arch" in \
    'x86_64')LIBS="g++ make git wget tzdata upx libpcap-dev openssh";; \
    'aarch64')LIBS="g++ make git wget tzdata libpcap-dev openssh binutils-gold";; \
    *)echo >&2 "error: unsupported architecture: '$arch'"; exit 1 ;; \
    esac; \
    apk add --no-cache $LIBS

RUN go env -w GOPRIVATE=*.ducesoft.net
RUN go env -w GOPROXY=https://mirrors.aliyun.com/goproxy/,https://goproxy.cn,https://goproxy.io,https://proxy.golang.org,direct
RUN git config --global url."https://gitlab-ci-token:iWDhGeW14C2RGUmD12ib@gitlab.ducesoft.net/".insteadOf https://gitlab.ducesoft.net/
RUN git config --global url."git@10.12.0.79:222".insteadOf "https://gitlab.ducesoft.net/"
RUN mkdir -p ~/.ssh && echo -e 'Host gitlab.ducesoft.net\n  Port 222' >> ~/.ssh/config
RUN echo 'ssh-rsa  noname' >> ~/.ssh/id_rsa.pub
RUN echo '' | base64 -d >> ~/.ssh/id_rsa
RUN ssh-keyscan -p 222 gitlab.ducesoft.net,10.12.0.79 >> ~/.ssh/known_hosts
RUN chmod 400 ~/.ssh/id_rsa && chmod 400 ~/.ssh/id_rsa.pub

COPY --from=ci /usr/bin/buildctl /usr/bin/
COPY --from=ci /usr/bin/kubectl /usr/bin/
COPY --from=ci /root/.m2/settings.xml /root/.m2/settings.xml
COPY --from=ci /root/.m2/settings-security.xml /root/.m2/settings-security.xml

CMD ["ash"]